<Window x:Class="FocalFade.Settings.QuickPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocalFade.Settings"
        Title="FocalFade Quick Panel"
        Width="320" Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="True"
        ResizeMode="NoResize"
        Deactivated="OnDeactivated"
        Loaded="OnLoaded">

    <Window.Resources>
        <!-- Dark theme brushes -->
        <SolidColorBrush x:Key="PanelBackground" Color="#E81E1E1E"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="CardBg" Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="AccentColor" Color="#5B9CF6"/>
        <SolidColorBrush x:Key="AccentDim" Color="#335B9CF6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#999999"/>
        <SolidColorBrush x:Key="TextMuted" Color="#666666"/>
        <SolidColorBrush x:Key="SliderTrack" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="SliderThumb" Color="#5B9CF6"/>
        <SolidColorBrush x:Key="ToggleOn" Color="#5B9CF6"/>
        <SolidColorBrush x:Key="ToggleOff" Color="#444444"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#22FFFFFF"/>

        <!-- Label style -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Value style -->
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Modern slider -->
        <Style TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="Background" Value="{StaticResource SliderTrack}"/>
        </Style>

        <!-- Quick color button -->
        <Style x:Key="ColorDot" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Width="28" Height="28" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderThickness="2" BorderBrush="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBackground}" CornerRadius="12"
            BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FocalFade" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="  Quick Panel" FontSize="16" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                </StackPanel>
                <TextBlock Text="Ctrl+Alt+Q to toggle" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Master toggle + mode -->
            <Border Grid.Row="1" Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <!-- Big toggle -->
                        <Border Width="44" Height="24" CornerRadius="12" Cursor="Hand"
                                MouseLeftButtonDown="OnToggleClick">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding Enabled, Converter={x:Static vm:QuickPanelWindow.BoolToToggleColor}}"/>
                            </Border.Background>
                            <Ellipse x:Name="ToggleDot" Width="18" Height="18" Fill="White" Margin="3" HorizontalAlignment="Left">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="{Binding Enabled, Converter={x:Static vm:QuickPanelWindow.BoolToToggleOffset}}"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <TextBlock Text="{Binding Enabled, Converter={x:Static vm:QuickPanelWindow.BoolToOnOff}}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBlock Text="Presentation" FontSize="10" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="16,0,0,0" Cursor="Hand"
                                   MouseLeftButtonDown="OnPresentationClick"/>
                        <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center" Margin="4,0,0,0" Cursor="Hand"
                                MouseLeftButtonDown="OnPresentationClick">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding PresentationMode, Converter={x:Static vm:QuickPanelWindow.BoolToAccentColor}}"/>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <ComboBox ItemsSource="{Binding OverlayModes}" SelectedItem="{Binding OverlayMode}"
                              Background="#22FFFFFF" Foreground="{StaticResource TextPrimary}" BorderBrush="#33FFFFFF"
                              FontSize="11" Height="24"/>
                </StackPanel>
            </Border>

            <!-- Opacity -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OPACITY" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding OpacityLabel}" Style="{StaticResource Value}" Margin="8,0,0,4"/>
                    </StackPanel>
                    <Slider Value="{Binding Opacity}" Minimum="0.10" Maximum="0.90"
                            TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                </StackPanel>
            </Border>

            <!-- Margin + Radius -->
            <Border Grid.Row="3" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MARGIN" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="{Binding MarginLabel}" Style="{StaticResource Value}" Margin="6,0,0,4"/>
                        </StackPanel>
                        <Slider Value="{Binding FocusMargin}" Minimum="0" Maximum="64"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="RADIUS" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="{Binding RadiusLabel}" Style="{StaticResource Value}" Margin="6,0,0,4"/>
                        </StackPanel>
                        <Slider Value="{Binding CornerRadius}" Minimum="0" Maximum="32"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Color -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="DIM COLOR" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding DimColor}" Style="{StaticResource Value}" Margin="8,0,0,4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <!-- Preview -->
                        <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,10,0"
                                BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding DimColorPreview}"/>
                            </Border.Background>
                        </Border>
                        <!-- Presets -->
                        <Button Style="{StaticResource ColorDot}" Command="{Binding ApplyQuickColorCommand}" CommandParameter="#000000">
                            <Button.Background><SolidColorBrush Color="#000000"/></Button.Background>
                        </Button>
                        <Button Style="{StaticResource ColorDot}" Command="{Binding ApplyQuickColorCommand}" CommandParameter="#2D3436">
                            <Button.Background><SolidColorBrush Color="#2D3436"/></Button.Background>
                        </Button>
                        <Button Style="{StaticResource ColorDot}" Command="{Binding ApplyQuickColorCommand}" CommandParameter="#1A2744">
                            <Button.Background><SolidColorBrush Color="#1A2744"/></Button.Background>
                        </Button>
                        <Button Style="{StaticResource ColorDot}" Command="{Binding ApplyQuickColorCommand}" CommandParameter="#3E2C1C">
                            <Button.Background><SolidColorBrush Color="#3E2C1C"/></Button.Background>
                        </Button>
                        <Button Style="{StaticResource ColorDot}" Command="{Binding ApplyQuickColorCommand}" CommandParameter="#1B0A2E">
                            <Button.Background><SolidColorBrush Color="#1B0A2E"/></Button.Background>
                        </Button>
                        <Button Style="{StaticResource ColorDot}" Command="{Binding ApplyQuickColorCommand}" CommandParameter="#0D2B2B">
                            <Button.Background><SolidColorBrush Color="#0D2B2B"/></Button.Background>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Blur -->
            <Border Grid.Row="5" Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="BLUR" Style="{StaticResource SectionLabel}"/>
                        <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center" Margin="6,0,0,4"
                                Cursor="Hand" MouseLeftButtonDown="OnBlurClick">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding BlurEnabled, Converter={x:Static vm:QuickPanelWindow.BoolToAccentColor}}"/>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="{Binding BlurLabel}" Style="{StaticResource Value}" Margin="8,0,0,4"/>
                    </StackPanel>
                    <Slider Value="{Binding BlurIntensity}" Minimum="0.1" Maximum="1.0"
                            TickFrequency="0.05" IsSnapToTickEnabled="True" IsEnabled="{Binding BlurEnabled}"/>
                </StackPanel>
            </Border>

            <!-- Border toggle -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,6,0,0">
                <CheckBox Content="Show border" IsChecked="{Binding ShowBorder}" Foreground="{StaticResource TextSecondary}"
                          FontSize="11"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
