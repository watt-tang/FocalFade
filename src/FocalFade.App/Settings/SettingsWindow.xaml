<Window x:Class="FocalFade.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocalFade.Settings"
        Title="FocalFade Settings"
        Width="560" Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource TextForeground}">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>
        <SolidColorBrush x:Key="TextForeground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4A7DDB"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="FocalFade Settings" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Configure how FocalFade helps you focus" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- General -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="General" Style="{StaticResource SectionHeader}"/>
                        <CheckBox Content="Enable FocalFade" IsChecked="{Binding Enabled}" Margin="0,0,0,6"/>
                        <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="0,0,0,6"/>
                        <CheckBox Content="Start enabled" IsChecked="{Binding StartEnabled}" Margin="0,0,0,6"/>
                        <CheckBox Content="Pause on fullscreen apps" IsChecked="{Binding PauseOnFullscreen}" Margin="0,0,0,6"/>
                        <CheckBox Content="Hide overlay while dragging windows" IsChecked="{Binding HideOverlayWhileDragging}" Margin="0,0,0,6"/>
                        <CheckBox Content="Presentation Mode" IsChecked="{Binding PresentationModeEnabled}" Margin="0,0,0,6"/>
                    </StackPanel>
                </Border>

                <!-- Appearance -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Opacity" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Slider Value="{Binding Opacity}" Minimum="0.10" Maximum="0.90"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True" Width="280"/>
                            <TextBlock Text="{Binding OpacityPercent}" Margin="12,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>

                        <TextBlock Text="Focus Margin" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Slider Value="{Binding FocusMargin}" Minimum="0" Maximum="64"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Width="280"/>
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}">
                                <TextBlock.Text><MultiBinding StringFormat="{}{0:F0} px"><Binding Path="FocusMargin"/></MultiBinding></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="Corner Radius" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Slider Value="{Binding CornerRadius}" Minimum="0" Maximum="32"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Width="280"/>
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}">
                                <TextBlock.Text><MultiBinding StringFormat="{}{0:F0} px"><Binding Path="CornerRadius"/></MultiBinding></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <!-- Enhanced Color Picker -->
                        <TextBlock Text="Dim Color" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>

                        <!-- Preview swatch + hex input -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="40" Height="40" CornerRadius="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding DimColorPreview}"/>
                                </Border.Background>
                            </Border>
                            <TextBox Text="{Binding DimColor, UpdateSourceTrigger=LostFocus}" Width="100"
                                     VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Consolas"/>
                        </StackPanel>

                        <!-- RGB sliders -->
                        <StackPanel Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="R" Width="20" Foreground="#C00" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Slider Value="{Binding ColorR}" Minimum="0" Maximum="255" TickFrequency="1"
                                        IsSnapToTickEnabled="True" Width="240" Margin="4,0,0,0"/>
                                <TextBlock Text="{Binding ColorR}" Width="30" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="G" Width="20" Foreground="#0A0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Slider Value="{Binding ColorG}" Minimum="0" Maximum="255" TickFrequency="1"
                                        IsSnapToTickEnabled="True" Width="240" Margin="4,0,0,0"/>
                                <TextBlock Text="{Binding ColorG}" Width="30" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="B" Width="20" Foreground="#00C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Slider Value="{Binding ColorB}" Minimum="0" Maximum="255" TickFrequency="1"
                                        IsSnapToTickEnabled="True" Width="240" Margin="4,0,0,0"/>
                                <TextBlock Text="{Binding ColorB}" Width="30" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Presets -->
                        <TextBlock Text="Presets" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,4"/>
                        <ItemsControl ItemsSource="{Binding ColorPresets}" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="6,3" Margin="0,0,6,4" Command="{Binding DataContext.ApplyColorPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,4,0" BorderBrush="#CCC" BorderThickness="1">
                                                <Border.Background><SolidColorBrush Color="{Binding Hex, Converter={x:Static vm:SettingsWindow.HexToColorConverter}}"/></Border.Background>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <CheckBox Content="Show border around focused window" IsChecked="{Binding ShowBorder}" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable animations" IsChecked="{Binding AnimationsEnabled}" Margin="0,0,0,6"/>
                    </StackPanel>
                </Border>

                <!-- Blur Effect -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Blur Effect (Experimental)" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Applies a blur behind dimmed areas. Focused window stays clear."
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <CheckBox Content="Enable blur behind dimmed areas" IsChecked="{Binding BlurEnabled}" Margin="0,0,0,8"/>
                        <StackPanel IsEnabled="{Binding BlurEnabled}">
                            <TextBlock Text="Blur Intensity" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <Slider Value="{Binding BlurIntensity}" Minimum="0.1" Maximum="1.0"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True" Width="280"/>
                                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}">
                                    <TextBlock.Text><MultiBinding StringFormat="{}{0:P0}"><Binding Path="BlurIntensity"/></MultiBinding></TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Focus Behavior -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Focus Behavior" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Focus Mode" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding OverlayModes}" SelectedItem="{Binding OverlayMode}" Width="200" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                        <TextBlock Text="Fullscreen Behavior" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding FullscreenBehaviors}" SelectedItem="{Binding FullscreenBehavior}" Width="200" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    </StackPanel>
                </Border>

                <!-- App Rules -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="App Rules" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Excluded apps and per-app opacity overrides" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                        <ListBox x:Name="AppRulesListBox" ItemsSource="{Binding AppRules}" MaxHeight="180" Margin="0,0,0,8" BorderBrush="{DynamicResource BorderBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding Enabled}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" (" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                        <TextBlock Text=")" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                        <TextBlock Margin="8,0,0,0" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <Binding Path="OpacityOverride" StringFormat=" Opacity: {0:P0}" FallbackValue=""/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Add Current App" Command="{Binding AddCurrentAppCommand}" Margin="0,0,8,0" Padding="12,4"/>
                            <Button Content="Toggle Opacity" Command="{Binding SetRuleOpacityCommand}" CommandParameter="{Binding SelectedItem, ElementName=AppRulesListBox}" Margin="0,0,8,0" Padding="12,4"/>
                            <Button Content="Remove" Command="{Binding RemoveSelectedRuleCommand}" Padding="12,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hotkeys (click-to-bind) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Hotkeys" Style="{StaticResource SectionHeader}" Margin="0,0,8,0"/>
                            <Button Content="Reset All" Command="{Binding ResetAllHotkeysCommand}" Padding="8,2" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="Click a hotkey field, then press your desired key combination."
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding HotkeyBindings}" Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding DisplayName}" Width="160" VerticalAlignment="Center" FontSize="12"/>
                                        <vm:HotkeyCaptureControl Width="200" VerticalAlignment="Center"
                                            Binding="{Binding}"
                                            AllBindings="{Binding DataContext.HotkeyBindings, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <TextBlock Text="{Binding DefaultGesture}" Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Tray Icon Theme -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Tray Icon" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Theme" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding TrayIconThemes}" SelectedItem="{Binding TrayIconTheme}" Width="150" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Diagnostics -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Diagnostics" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8">
                            <Run Text="Version: "/><Run Text="{Binding Version, Mode=OneWay}"/>
                        </TextBlock>
                        <CheckBox Content="Verbose logging" IsChecked="{Binding VerboseLogging}" Margin="0,0,0,6"/>
                        <CheckBox Content="Show overlay diagnostics" IsChecked="{Binding ShowOverlayDiagnostics}" Margin="0,0,0,12"/>
                        <Button Content="Reset to Defaults" Command="{Binding ResetToDefaultsCommand}" Padding="12,4"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
