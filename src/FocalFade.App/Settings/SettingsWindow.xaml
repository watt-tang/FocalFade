<Window x:Class="FocalFade.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocalFade.Settings"
        Title="FocalFade Settings"
        Width="520" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource TextForeground}">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>
        <SolidColorBrush x:Key="TextForeground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4A7DDB"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="Row" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="FocalFade Settings" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextForeground}"/>
            <TextBlock Text="Configure how FocalFade helps you focus" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- General Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="General" Style="{StaticResource SectionHeader}"/>
                        <CheckBox Content="Enable FocalFade" IsChecked="{Binding Enabled}" Margin="0,0,0,6"/>
                        <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="0,0,0,6"/>
                        <CheckBox Content="Start enabled" IsChecked="{Binding StartEnabled}" Margin="0,0,0,6"/>
                        <CheckBox Content="Pause on fullscreen apps" IsChecked="{Binding PauseOnFullscreen}" Margin="0,0,0,6"/>
                        <CheckBox Content="Presentation Mode" IsChecked="{Binding PresentationModeEnabled}" Margin="0,0,0,6"/>
                    </StackPanel>
                </Border>

                <!-- Appearance Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Opacity" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Slider Value="{Binding Opacity}" Minimum="0.10" Maximum="0.90"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Width="280" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OpacityPercent}" Margin="12,0,0,0"
                                       VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>

                        <TextBlock Text="Focus Margin" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Slider Value="{Binding FocusMargin}" Minimum="0" Maximum="64"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Width="280" VerticalAlignment="Center"/>
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} px">
                                        <Binding Path="FocusMargin"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="Corner Radius" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Slider Value="{Binding CornerRadius}" Minimum="0" Maximum="32"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Width="280" VerticalAlignment="Center"/>
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} px">
                                        <Binding Path="CornerRadius"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="Dim Color" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton Content="Black" GroupName="DimColor"
                                         IsChecked="{Binding DimColor, Converter={x:Static vm:SettingsWindow.BlackColorConverter}}"
                                         Margin="0,0,12,0"/>
                            <RadioButton Content="Dark Gray" GroupName="DimColor"
                                         IsChecked="{Binding DimColor, Converter={x:Static vm:SettingsWindow.DarkGrayConverter}}"
                                         Margin="0,0,12,0"/>
                            <RadioButton Content="Dark Blue" GroupName="DimColor"
                                         IsChecked="{Binding DimColor, Converter={x:Static vm:SettingsWindow.DarkBlueConverter}}"
                                         Margin="0,0,12,0"/>
                        </StackPanel>

                        <CheckBox Content="Show border around focused window" IsChecked="{Binding ShowBorder}" Margin="0,4,0,6"/>
                        <CheckBox Content="Enable animations" IsChecked="{Binding AnimationsEnabled}" Margin="0,0,0,6"/>
                    </StackPanel>
                </Border>

                <!-- Focus Behavior Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Focus Behavior" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Focus Mode" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding OverlayModes}" SelectedItem="{Binding OverlayMode}"
                                  Width="200" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                        <TextBlock Text="Fullscreen Behavior" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding FullscreenBehaviors}" SelectedItem="{Binding FullscreenBehavior}"
                                  Width="200" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    </StackPanel>
                </Border>

                <!-- App Rules Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="App Rules" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Apps excluded from dimming" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>

                        <ListBox ItemsSource="{Binding AppRules}" MaxHeight="180" Margin="0,0,0,8"
                                 BorderBrush="{DynamicResource BorderBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding Enabled}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" (" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                        <TextBlock Text=")" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Add Current App" Command="{Binding AddCurrentAppCommand}"
                                    Margin="0,0,8,0" Padding="12,4"/>
                            <Button Content="Remove Selected" Command="{Binding RemoveSelectedRuleCommand}"
                                    Padding="12,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hotkeys Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Hotkeys" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Default hotkeys (editing coming in a future release)" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>

                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Foreground="{DynamicResource TextForeground}">
                                <Run Text="Ctrl+Alt+F" FontWeight="SemiBold"/>
                                <Run Text="  Toggle enabled"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Foreground="{DynamicResource TextForeground}">
                                <Run Text="Ctrl+Alt+Up" FontWeight="SemiBold"/>
                                <Run Text="  Increase opacity"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Foreground="{DynamicResource TextForeground}">
                                <Run Text="Ctrl+Alt+Down" FontWeight="SemiBold"/>
                                <Run Text="  Decrease opacity"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Foreground="{DynamicResource TextForeground}">
                                <Run Text="Ctrl+Alt+P" FontWeight="SemiBold"/>
                                <Run Text="  Presentation mode"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Foreground="{DynamicResource TextForeground}">
                                <Run Text="Ctrl+Alt+Space" FontWeight="SemiBold"/>
                                <Run Text="  Peek (10 sec)"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Diagnostics Section -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Diagnostics" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8">
                            <Run Text="Version: "/>
                            <Run Text="{Binding Version, Mode=OneWay}"/>
                        </TextBlock>

                        <CheckBox Content="Verbose logging" IsChecked="{Binding VerboseLogging}" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Reset to Defaults" Command="{Binding ResetToDefaultsCommand}"
                                    Padding="12,4" Margin="0,0,8,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
