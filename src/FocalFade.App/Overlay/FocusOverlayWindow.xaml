<Window x:Class="FocalFade.Overlay.FocusOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FocalFade Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        Left="0" Top="0" Width="100" Height="100"
        Loaded="OnLoaded">
    <Canvas x:Name="OverlayCanvas">
        <Path x:Name="DimmingPath"
              Fill="Black"
              Opacity="0.45"
              IsHitTestVisible="False" />
        <Path x:Name="BorderPath"
              Stroke="White"
              StrokeThickness="1"
              Opacity="0.3"
              Fill="Transparent"
              IsHitTestVisible="False"
              Visibility="Collapsed" />
    </Canvas>
</Window>
